# MongoDB connection string (local or remote)
MONGO_URI=mongodb://localhost:27017/

# JWT secret key — generate a strong random string for production
JWT_SECRET=your_jwt_secret_here

# Email credentials for password-reset emails (Gmail app password recommended)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password

# Frontend URL for CORS and password-reset links
FRONTEND_URL=http://localhost:3000

# Backend server port
PORT=5000

# Hugging Face API key (optional — only needed if you enable AI chatbot)
HUGGINGFACE_API_KEY=hf_your_key_here
